{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      },
      "models": {
        "qwen3.5:27b": {
          "name": "Qwen 3.5 27b"
        }
      }
    }
  },
  "model": "venice/kimi-k2-6",
  "agent": {
    "researcher": {
      "mode": "primary",
      "description": "Primary research agent. Plans work, delegates web search, writes and organizes files, saves provenance, and records changes in git.",
      "model": "venice/kimi-k2-6",
      "prompt": "{file:./prompts/researcher.md}",
      "temperature": 0.2,
      "steps": 40,
      "color": "accent",
      "permission": {
        "bash": {
          "*": "deny",
          "cp *": "allow",
          "curl *": "allow",
          "file *": "allow",
          "git *": "allow",
          "grep *": "allow",
          "head *": "allow",
          "html2text *": "allow",
          "ls*": "allow",
          "mkdir *": "allow",
          "mv *": "allow",
          "pdftotext *": "allow",
          ".research/bin/research-run-init.py *": "allow",
          ".research/bin/research-run-validate.py *": "allow"
        },
        "codesearch": "deny",
        "doom_loop": "ask",
        "edit": "allow",
        "external_directory": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "deny",
        "question": "allow",
        "read": "allow",
        "skill": "deny",
        "task": {
          "*": "deny",
          "web-searcher": "allow"
        },
        "todowrite": "deny",
        "webfetch": "allow",
        "websearch": "deny"
      }
    },
    "web-searcher": {
      "mode": "subagent",
      "hidden": true,
      "description": "Web-only search subagent for a single research thread. Runs several query variations, fetches high-signal pages, and returns a concise evidence bundle.",
      "model": "venice/minimax-m27",
      "prompt": "{file:./prompts/web-searcher.md}",
      "temperature": 0.2,
      "steps": 30,
      "color": "info",
      "permission": {
        "bash": "deny",
        "codesearch": "deny",
        "doom_loop": "ask",
        "edit": {
          "*": "deny",
          ".research/runs/**": "allow"
        },
        "external_directory": "deny",
        "glob": "deny",
        "grep": "deny",
        "list": "deny",
        "lsp": "deny",
        "question": "deny",
        "read": "deny",
        "skill": "deny",
        "task": "deny",
        "todowrite": "deny",
        "webfetch": "allow",
        "websearch": "allow"
      }
    }
  }
}
