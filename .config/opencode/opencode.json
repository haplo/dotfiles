{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "plugin": [
    "opencode-firecrawl"
  ],
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      },
      "models": {
        "qwen3.5:27b": {
          "name": "Qwen 3.5 27b"
        }
      }
    }
  },
  "model": "venice/kimi-k2-6",
  "agent": {
    "researcher": {
      "mode": "primary",
      "description": "Primary research agent. Plans work, searches the web, writes and organizes files, saves provenance, and records changes in git.",
      "model": "venice/minimax-m3",
      "prompt": "{file:./prompts/researcher.md}",
      "temperature": 0.2,
      "steps": 50,
      "color": "accent",
      "permission": {
        "bash": "allow",
        "codesearch": "deny",
        "doom_loop": "ask",
        "edit": "allow",
        "external_directory": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "deny",
        "question": "allow",
        "read": "allow",
        "skill": "allow",
        "task": "deny",
        "todowrite": "deny",
        "webfetch": "allow",
        "websearch": "allow"
      }
    }
  }
}
