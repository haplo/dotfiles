{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "plugin": [
    "opencode-firecrawl"
  ],
  "model": "venice/zai-org-glm-5-2",
  "agent": {
    "researcher": {
      "mode": "primary",
      "description": "Primary research agent. Plans work, delegates web search, writes and organizes files, saves provenance, and records changes in git.",
      "model": "venice/minimax-m3",
      "prompt": "{file:./prompts/researcher.md}",
      "temperature": 0.2,
      "steps": 50,
      "color": "accent",
      "permission": {
        "bash": "allow",
        "codesearch": "deny",
        "doom_loop": "ask",
        "edit": "allow",
        "external_directory": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "deny",
        "question": "allow",
        "read": "allow",
        "skill": "allow",
        "task": {
          "*": "deny",
          "web-searcher": "allow"
        },
        "todowrite": "deny",
        "webfetch": "allow",
        "websearch": "deny"
      }
    },
    "web-searcher": {
      "mode": "subagent",
      "hidden": true,
      "description": "Web-only search subagent for a single research thread. Runs several query variations, fetches high-signal pages, and returns a concise evidence bundle.",
      "model": "venice/minimax-m3",
      "prompt": "{file:./prompts/web-searcher.md}",
      "temperature": 0.2,
      "steps": 60,
      "color": "info",
      "permission": {
        "bash": "allow",
        "codesearch": "deny",
        "doom_loop": "ask",
        "edit": {
          "*": "deny",
          "**/runs/**": "allow"
        },
        "external_directory": "deny",
        "glob": "deny",
        "grep": "deny",
        "list": "deny",
        "lsp": "deny",
        "question": "deny",
        "read": "deny",
        "skill": "allow",
        "task": "deny",
        "todowrite": "deny",
        "webfetch": "allow",
        "websearch": "allow"
      }
    }
  }
}
